# Local-only example. Copy to .env.local and fill values from this machine.
# .env.local is ignored by git.

SPRING_PROFILES_ACTIVE=local

MYSQL_HOST=127.0.0.1
MYSQL_PORT=33306
MYSQL_DATABASE=yudao_xinghe_xunjing
MYSQL_USERNAME=xunjing
MYSQL_PASSWORD=xunjing_local_password

REDIS_HOST=127.0.0.1
REDIS_PORT=36379
REDIS_DATABASE=0
REDIS_PASSWORD=xunjing_local_redis_password
REDIS_KEY_PREFIX=xj:

OSS_ENDPOINT=http://127.0.0.1:39000
OSS_REGION=
OSS_BUCKET=xinghe-xunjing
OSS_PREFIX=assets/
OSS_ACCESS_KEY=
OSS_SECRET_KEY=

QDRANT_URL=http://127.0.0.1:36333
