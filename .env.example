# Xinghe Xunjing backend environment template.
# Copy to .env.local for local development. Do not commit real values.

SPRING_PROFILES_ACTIVE=local
XUNJING_TENANT_ID=1

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=yudao_xinghe_xunjing
MYSQL_USERNAME=xunjing
MYSQL_PASSWORD=

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DATABASE=0
REDIS_PASSWORD=replace_with_redis_password
REDIS_KEY_PREFIX=xj:

OSS_ENDPOINT=
OSS_REGION=
OSS_BUCKET=xinghe-xunjing
OSS_PREFIX=assets/
OSS_ACCESS_KEY=
OSS_SECRET_KEY=

QDRANT_URL=
QDRANT_HOST=
QDRANT_GRPC_PORT=
QDRANT_API_KEY=
QDRANT_TEXT_COLLECTION=xinghe_xunjing_text_local
QDRANT_IMAGE_COLLECTION=xinghe_xunjing_image_local

QWEN_BASE_URL=
QWEN_API_KEY=
QWEN_MODEL=
QWEN_EMBEDDING_MODEL=
DASHSCOPE_API_KEY=
DASHSCOPE_ENABLED=false
DASHSCOPE_AGENT_ENABLED=false
DASHSCOPE_CHAT_ENABLED=false
DASHSCOPE_EMBEDDING_ENABLED=false
DASHSCOPE_IMAGE_ENABLED=false
SPRING_AI_MODEL_CHAT=none
SPRING_AI_MODEL_EMBEDDING=none
SPRING_AI_MODEL_IMAGE=none
SPRING_AI_MODEL_MODERATION=none
SPRING_AI_MODEL_AUDIO_SPEECH=none
SPRING_AI_MODEL_AUDIO_TRANSCRIPTION=none
SPRING_AI_MODEL_VIDEO=none

# Yudao native AI provider keys. Keep empty unless the provider is enabled.
MYBATIS_PLUS_ENCRYPTOR_PASSWORD=
YUDAO_API_ENCRYPT_REQUEST_KEY=replace_with_16_24_or_32_byte_secret
YUDAO_API_ENCRYPT_RESPONSE_KEY=replace_with_16_24_or_32_byte_secret
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
STABILITY_AI_API_KEY=
SILICONFLOW_API_KEY=
MIDJOURNEY_API_KEY=
BOCHA_WEB_SEARCH_API_KEY=
GEMINI_API_KEY=
DOUBAO_API_KEY=
XINGHUO_APP_KEY=
XINGHUO_SECRET_KEY=
YUDAO_AI_QIANFAN_API_KEY=
YUDAO_AI_QIANFAN_SECRET_KEY=
YUDAO_AI_ZHIPUAI_API_KEY=

# Optional logistics/provider integrations retained from Yudao.
KD100_KEY=
KD100_CUSTOMER=
KDNIAO_API_KEY=
KDNIAO_BUSINESS_ID=

INTERNAL_AUTH_TOKEN=
CRAWLER_USER_AGENT=XingheXunjingBot/1.0
CRAWLER_MAX_CONCURRENCY=2
CRAWLER_REQUEST_TIMEOUT_MS=15000
