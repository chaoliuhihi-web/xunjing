{
  "name": "xinghexunjing",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "test": "vitest",
    "test:run": "vitest --run",
    "qa:smoke": "node scripts/smoke-site.mjs",
    "release:check": "npm run test:run && npm audit --audit-level=moderate && npm run build",
    "release:package": "npm run release:check && node scripts/package-release.mjs",
    "deploy:verify": "node scripts/verify-deployment.mjs",
    "xunjing:platform:verify": "node scripts/verify-xunjing-platform-readiness.mjs",
    "xunjing:platform:verify:static": "node scripts/verify-xunjing-platform-readiness.mjs --static",
    "xunjing:yudao:release:gate": "node scripts/verify-xicheng-yudao-release-readiness.mjs",
    "xunjing:yudao:release:tasks:export": "node scripts/export-xicheng-yudao-release-blocker-tasks.mjs",
    "xunjing:xicheng:poi:review:pack": "node scripts/create-xicheng-poi-production-review-pack.mjs",
    "xunjing:xicheng:poi:manifest:template": "node scripts/create-xicheng-poi-production-manifest-template.mjs",
    "xunjing:xicheng:poi:workbook:gate": "node scripts/verify-xicheng-poi-review-workbook.mjs",
    "xunjing:xicheng:poi:tasks:export": "node scripts/export-xicheng-poi-review-tasks.mjs",
    "xunjing:xicheng:poi:manifest:from-workbook": "node scripts/build-xicheng-poi-production-manifest-from-workbook.mjs",
    "xunjing:xicheng:poi:manifest:gate": "node scripts/verify-xicheng-poi-production-manifest.mjs",
    "xunjing:xicheng:poi:seed:generate": "node scripts/generate-xicheng-poi-production-seed.mjs",
    "xunjing:xicheng:poi:seed:verify": "node scripts/verify-xicheng-poi-production-seed.mjs",
    "xunjing:xicheng:release:evidence:package": "node scripts/verify-xicheng-release-evidence-package.mjs",
    "xunjing:ai:bootstrap": "node scripts/bootstrap-yudao-ai-model.mjs",
    "xunjing:platform:deps:config": "docker compose -f ops/xunjing-platform.compose.yml --env-file ops/xunjing-platform.env.example config",
    "xunjing:platform:deps:up": "docker compose -f ops/xunjing-platform.compose.yml --env-file ops/xunjing-platform.env up -d",
    "xunjing:platform:deps:down": "docker compose -f ops/xunjing-platform.compose.yml --env-file ops/xunjing-platform.env down"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.8",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@vitejs/plugin-react": "^4.7.0",
    "jsdom": "^24.1.1",
    "playwright": "^1.61.0",
    "vite": "^6.4.3",
    "vitest": "^4.1.9"
  }
}
