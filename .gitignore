.DS_Store
**/.DS_Store
**/~$*

# Local env and runtime secrets
.env
.env.local
.env.*.local
ops/*.env
!ops/*.env.example
.runtime/

# Local archives and temporary files
archive/
tmp/
downloads/
node_modules/
.playwright-mcp/

# Large generated packages and media
*.zip
*.mp4
*.gif

# Frontend build and test outputs
dist/
playwright-report/
test-results/

# Backend build and local dependency outputs
backend/yudao/**/target/
backend/yudao/**/node_modules/
backend/yudao/**/dist/
backend/yudao/**/.flattened-pom.xml
backend/yudao/**/.idea/
backend/yudao/**/.runtime/
backend/yudao/yudao-server/src/main/resources/application-local.yaml
backend/yudao/yudao-server/src/main/resources/application-dev.yaml
backend/yudao/yudao-server/src/main/resources/application-prod.yaml

# Keep only the website reference assets required by src/data/siteContent.js
assets/references/*
!assets/references/Web_V3/
!assets/references/Web_V3/*.png
!assets/references/product_effects/
!assets/references/product_effects/*.png

# Local production workbenches and heavy handoff artifacts
workbench/
deliverables/

# PPT generation scratch files
workbench/**/.live_preview.lock
workbench/**/backup/
workbench/**/tmp_review/
workbench/**/exports/~$*
