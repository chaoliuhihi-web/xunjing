# Copy to a secure path such as /secure/path/production.env before release.
# Do not commit the real production env file or any filled secret values.

SPRING_PROFILES_ACTIVE=production
SPRING_AI_VECTORSTORE_TYPE=qdrant
SPRING_AI_MODEL_EMBEDDING=dashscope
XUNJING_TENANT_ID=replace-with-production-tenant-id
XUNJING_APP_API_BASE_URL=https://replace-with-production-api.example.com

MYSQL_HOST=replace-with-production-mysql-host
MYSQL_PORT=3306
MYSQL_DATABASE=replace-with-production-database
MYSQL_USERNAME=replace-with-production-mysql-user
MYSQL_PASSWORD=replace-with-production-mysql-password

REDIS_HOST=replace-with-production-redis-host
REDIS_PORT=6379
REDIS_DATABASE=0
REDIS_PASSWORD=replace-with-production-redis-password

OSS_ENDPOINT=https://replace-with-production-oss-endpoint.example.com
OSS_BUCKET=replace-with-production-bucket
OSS_PREFIX=xinghe-xunjing/production/
OSS_ACCESS_KEY=replace-with-production-oss-access-key
OSS_SECRET_KEY=replace-with-production-oss-secret-key
OSS_REGION=replace-with-production-oss-region
OSS_PATH_STYLE=false

QDRANT_URL=https://replace-with-production-qdrant.example.com
QDRANT_HOST=replace-with-production-qdrant-host
QDRANT_GRPC_PORT=6334
QDRANT_API_KEY=replace-with-production-qdrant-api-key
QDRANT_TEXT_COLLECTION=xinghe_xunjing_text_production
QDRANT_IMAGE_COLLECTION=xinghe_xunjing_image_production
XICHENG_QDRANT_EVIDENCE=qa/xicheng-qdrant-smoke-evidence.json

QWEN_API_KEY=replace-with-production-qwen-api-key
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus
DASHSCOPE_API_KEY=replace-with-production-dashscope-api-key
DASHSCOPE_EMBEDDING_ENABLED=true

WX_MP_APP_ID=replace-with-production-wechat-mp-app-id
WX_MP_SECRET=replace-with-production-wechat-mp-secret
WX_MINIAPP_APPID=replace-with-production-wechat-miniapp-app-id
WX_MINIAPP_SECRET=replace-with-production-wechat-miniapp-secret

XUNJING_VISION_API_URL=https://replace-with-production-vision.example.com/xunjing/recognize
XUNJING_VISION_API_KEY=replace-with-production-vision-api-key
XUNJING_VISION_MODEL=replace-with-production-vision-model

INTERNAL_AUTH_TOKEN=replace-with-production-internal-auth-token
