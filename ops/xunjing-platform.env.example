# Copy to ops/xunjing-platform.env for local dependency containers.
# Do not put production secrets here.

MYSQL_ROOT_PASSWORD=xunjing_local_root
MYSQL_DATABASE=yudao_xinghe_xunjing
MYSQL_USERNAME=xunjing
MYSQL_PASSWORD=xunjing_local_password
XUNJING_MYSQL_PORT=33306

REDIS_HOST=127.0.0.1
REDIS_PORT=36379
REDIS_DATABASE=0
REDIS_PASSWORD=xunjing_local_redis_password
REDIS_KEY_PREFIX=xj:
XUNJING_REDIS_PORT=36379

QDRANT_URL=http://127.0.0.1:36333
QDRANT_HOST=127.0.0.1
QDRANT_GRPC_PORT=36334
QDRANT_TEXT_COLLECTION=xinghe_xunjing_text_local
QDRANT_IMAGE_COLLECTION=xinghe_xunjing_image_local
XUNJING_QDRANT_HTTP_PORT=36333
XUNJING_QDRANT_GRPC_PORT=36334

MINIO_ROOT_USER=xunjingminio
MINIO_ROOT_PASSWORD=xunjing_local_minio_password
MINIO_BUCKET=xinghe-xunjing
XUNJING_MINIO_API_PORT=39000
XUNJING_MINIO_CONSOLE_PORT=39001

OSS_ENDPOINT=http://127.0.0.1:39000
OSS_BUCKET=xinghe-xunjing
OSS_PREFIX=xinghe-xunjing/local/
OSS_ACCESS_KEY=xunjingminio
OSS_SECRET_KEY=xunjing_local_minio_password
